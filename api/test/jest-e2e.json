{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^@src/(.*)$": "<rootDir>/../src/$1"
  },
  "setupFiles": [
    "<rootDir>/helpers/setup-env.ts"
  ],
  "testTimeout": 60000,
  "forceExit": true,
  "runInBand": true,
  "verbose": true
}
