# ============================================
# MERO JUGX - Test Environment Configuration
# ============================================
# Used automatically when NODE_ENV=test
# Points to a SEPARATE test database so tests never touch production data

# ============================================
# APPLICATION
# ============================================
NODE_ENV=test
PORT=3001
API_PREFIX=api
API_VERSION=v1
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3002

# ============================================
# DATABASE (separate test database)
# ============================================
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mero_jugx_test

DB_POOL_MAX=5
DB_POOL_MIN=1
DB_POOL_IDLE_TIMEOUT=10000
DB_POOL_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# Sync OFF — tests use migrations
DB_SYNCHRONIZE=false
# Logging OFF in tests (reduces noise)
DB_LOGGING=false

# Auto-run migrations when test app boots
AUTO_INIT_DB=true

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=test_jwt_secret_key_do_not_use_in_production
JWT_REFRESH_SECRET=test_jwt_refresh_secret_key_do_not_use_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# EMAIL — disabled in tests (use mock)
# ============================================
RESEND_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=test
SMTP_PASSWORD=test
SMTP_FROM=noreply@test.com
SMTP_FROM_NAME=Mero Jugx Test

# ============================================
# 2FA / MFA
# ============================================
TOTP_ISSUER=Mero Jugx Test
TOTP_ALGORITHM=SHA1
TOTP_DIGITS=6
TOTP_PERIOD=30

# ============================================
# RATE LIMITING — relaxed for tests
# ============================================
THROTTLE_TTL=1
THROTTLE_LIMIT=1000

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_DEST=./uploads/test

# ============================================
# LOGGING — minimal in tests
# ============================================
LOG_LEVEL=error
LOG_DIR=./logs/test

# ============================================
# SENTRY — disabled in tests
# ============================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ============================================
# CACHING
# ============================================
CACHE_TTL=60

# ============================================
# PAYMENT GATEWAYS — all in mock/sandbox mode
# ============================================

# eSewa sandbox
ESEWA_TEST_MERCHANT_ID=EPAYTEST
ESEWA_TEST_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_TEST_API_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_TEST_VERIFY_URL=https://rc.esewa.com.np/api/epay/transaction/status
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_API_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_VERIFY_URL=https://rc.esewa.com.np/api/epay/transaction/status
# Use mock mode so tests don't hit real eSewa servers
ESEWA_USE_MOCK_MODE=true

# Stripe test mode
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_TEST_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_test_placeholder

# ============================================
# CURRENCY & REGION
# ============================================
NPR_TO_USD_RATE=0.0075
DEFAULT_CURRENCY=NPR
NEPAL_COUNTRY_CODE=NP

# ============================================
# SMS / WHATSAPP — disabled in tests
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ============================================
# PUSH NOTIFICATIONS — disabled in tests
# ============================================
FIREBASE_SERVER_KEY=
